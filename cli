#!/usr/bin/env bash
set -euo pipefail

BUILD_DIR="build"
SRC_CPP=$(find src -name "*.cpp" -o -name "*.h" 2>/dev/null | tr '\n' ' ')
ALL_CPP=$(find src tests -name "*.cpp" -o -name "*.h" 2>/dev/null | tr '\n' ' ')

require_build() {
    if [ ! -d "$BUILD_DIR" ]; then
        echo "error: build directory not found — run './cli build' first"
        exit 1
    fi
}

require_compile_commands() {
    require_build
    if [ ! -f "$BUILD_DIR/compile_commands.json" ]; then
        echo "error: compile_commands.json missing — run './cli build' first"
        exit 1
    fi
}

cmd=${1:-help}

case "$cmd" in

    build)
        cmake -B "$BUILD_DIR" \
              -DCMAKE_BUILD_TYPE=Debug \
              -DCMAKE_EXPORT_COMPILE_COMMANDS=ON
        cmake --build "$BUILD_DIR" --parallel
        ;;

    test)
        require_build
        cd "$BUILD_DIR" && ctest --output-on-failure
        ;;

    lint)
        require_compile_commands
        # shellcheck disable=SC2086
        clang-tidy -p "$BUILD_DIR" $SRC_CPP
        ;;

    format)
        # shellcheck disable=SC2086
        clang-format -i $ALL_CPP
        echo "formatted all source files"
        ;;

    format-check)
        # shellcheck disable=SC2086
        clang-format --dry-run --Werror $ALL_CPP
        ;;

    clean)
        rm -rf "$BUILD_DIR"
        echo "cleaned build directory"
        ;;

    rebuild)
        rm -rf "$BUILD_DIR"
        cmake -B "$BUILD_DIR" \
              -DCMAKE_BUILD_TYPE=Debug \
              -DCMAKE_EXPORT_COMPILE_COMMANDS=ON
        cmake --build "$BUILD_DIR" --parallel
        ;;

    ci)
        # Full check: build → test → lint → format-check
        "$0" build
        "$0" test
        "$0" lint
        "$0" format-check
        ;;

    help|*)
        echo "usage: ./cli <command>"
        echo ""
        echo "  build          configure and build"
        echo "  test           run unit tests"
        echo "  lint           run clang-tidy static analysis"
        echo "  format         apply clang-format to all source files"
        echo "  format-check   check formatting without modifying files"
        echo "  rebuild        clean + build from scratch"
        echo "  ci             build → test → lint → format-check"
        echo "  clean          remove build directory"
        ;;

esac
